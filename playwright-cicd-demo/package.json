{
  "name": "playwright-cicd-demo",
  "version": "1.0.0",
  "private": true,
  "description": "Demo E2E (Playwright) + React + Express + GitHub Actions - Seminarium 9",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "build": "npm run build --workspace client",
    "start:server": "npm run start --workspace server",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:chromium": "playwright test --project=chromium",
    "test:visual": "playwright test --grep @visual --project=chromium",
    "test:update": "playwright test --grep @visual --project=chromium --update-snapshots",
    "report": "playwright show-report",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck --workspace client && npm run typecheck --workspace server && tsc --noEmit -p tsconfig.json",
    "codegen": "playwright codegen http://localhost:3000",
    "trace": "playwright show-trace"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.45.0",
    "@types/node": "^20.14.0",
    "concurrently": "^8.2.2",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.61.1"
  }
}
